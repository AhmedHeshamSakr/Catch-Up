# Copy to app/.env and fill in. NEVER commit app/.env (it is gitignored).
# Rotate any key that has ever been shared or committed.

# Gemini (Google AI Studio) — required for LLM enrichment, critic, narrative.
GOOGLE_API_KEY=

# GNews (gnews.io) — required only for `type: api` sources.
GNEWS_API_KEY=

# --- Optional product-API hardening ---
# Shared API key for the product REST API. When set, ALL /api/* routes require
# it (X-API-Key or Authorization: Bearer). Leave empty for local/dev (open).
API_KEY=

# Comma-separated CORS allowlist for the product API. Defaults to the local
# console origin when unset.
ALLOW_ORIGINS=http://localhost:3000
