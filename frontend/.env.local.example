# DEV ONLY (two-port `next dev` on :3000 → backend on :8000). Leave this UNSET for
# the single-port desktop build — production builds default to same-origin, and the
# launcher (scripts/run.sh) builds with NEXT_PUBLIC_API_BASE="" regardless.
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Optional: only for trusted/internal deploys. Sent as the X-API-Key header and
# must match the backend's API_KEY. NOTE: NEXT_PUBLIC_* is exposed to the
# browser — real per-user auth is a separate milestone.
NEXT_PUBLIC_API_KEY=
